# 服务器配置
PORT=3001
ENV=development

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=rss_llm_tts
DB_USER=root
DB_PASSWORD=Fl@123456

# LLM API配置
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-3.5-turbo

# TTS API配置
TTS_API_URL=https://api.openai.com/v1/audio/speech
TTS_API_KEY=your_openai_tts_key_here
TTS_VOICE=alloy
TTS_VOICE_HOST=alloy
TTS_VOICE_GUEST=nova

# HTTP代理配置
HTTP_PROXY_ENABLED=false
HTTP_PROXY_URL=

# RSS抓取配置
MAX_NEWS_PER_FEED=50
FETCH_TIMEOUT=8

# 对话生成配置
DIALOGUE_NEWS_COUNT=5
DIALOGUE_ROUNDS=8

# 文件存储配置
UPLOAD_PATH=./uploads
LOG_PATH=./logs
